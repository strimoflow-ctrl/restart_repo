async def start_automation():
    global TOTAL_FILES, DONE_COUNT, FAIL_COUNT, CURRENT_FILE_NAME, CURRENT_FILE_SIZE, CURRENT_ACTION, PROGRESS_PCT, CURRENT_SPEED, status_msg, PROMO_COUNTER, branding_text
    
    # Load dynamic credentials from Firebase config (Fallback to locally configured values)
    print("⏳ Checking dynamic configurations from Firebase Realtime DB...")
    global API_ID, API_HASH, SESSION_STRING, BOT_TOKEN, OWNER_CHAT_ID
    global KAGGLE_USERNAME, KAGGLE_KEY, KAGGLE_SLUG, SERVER_URL
    try:
        url = f"{FIREBASE_DB_URL}/{FIREBASE_FOLDER}/config.json"
        res = requests.get(url, timeout=10)
        config_data = res.json()
        if config_data:
            API_ID = config_data.get("api_id", API_ID)
            API_HASH = config_data.get("api_hash", API_HASH)
            SESSION_STRING = config_data.get("session_string", SESSION_STRING)
            BOT_TOKEN = config_data.get("bot_token", BOT_TOKEN)
            OWNER_CHAT_ID = config_data.get("owner_chat_id", OWNER_CHAT_ID)
            branding_text = config_data.get("extracted_by", branding_text)
            
            KAGGLE_USERNAME = config_data.get("kaggle_username", "")
            KAGGLE_KEY = config_data.get("kaggle_key", "")
            KAGGLE_SLUG = config_data.get("kaggle_slug", "")
            SERVER_URL = config_data.get("server_url", "")
            
            print("✅ Successfully synchronized credentials & settings from Firebase!")
    except Exception as e:
        print(f"[Warning] Firebase configuration sync skipped: {e}")

    # Fetch catalog from Firebase
    print("⏳ Fetching active course catalog...")
    catalog = []
    try:
        url = f"{FIREBASE_DB_URL}/{FIREBASE_FOLDER}/catalog.json"
        res = requests.get(url, timeout=15)
        catalog = res.json()
    except Exception as e:
        print(f"⚠️ Firebase catalog load failed: {e}")

    # Local fallback
    if not catalog:
        try:
            with open("courses_catalog.json", "r", encoding="utf-8") as f:
                catalog = json.load(f)
        except Exception as e:
            print(f"❌ Failed to load local backup catalog: {e}")
            return

    # Filter catalog based on ACTIVE_COURSE_KEY selection
    target_courses = []
    if ACTIVE_COURSE_KEY == "all":
        target_courses = catalog
    else:
        for item in catalog:
            if item.get("local_file", "").replace(".json", "").replace(".", "_") == ACTIVE_COURSE_KEY.replace(".", "_"):
                target_courses = [item]
                break

    if not target_courses:
        print(f"❌ No active courses found matching key: '{ACTIVE_COURSE_KEY}'!")
        return

    print(f"✅ Found {len(target_courses)} target courses to process.")

    # Initialize Telethon Clients
    clean_session = SESSION_STRING.strip().strip('"').strip("'").replace("\ufeff", "").replace(" ", "")
    clean_session = "".join(c for c in clean_session if c.isalnum() or c in "-_=")
    
    try:
        user_client = TelegramClient(StringSession(clean_session), API_ID, API_HASH)
    except Exception as e:
        print(f"❌ Session string decoding error: {e}")
        return

    bot_client = TelegramClient(MemorySession(), API_ID, API_HASH)

    print("🚀 Starting User Session and Bot status client...")
    try:
        await user_client.start()
    except Exception as e:
        print(f"❌ User session login failed: {e}")
        return

    await bot_client.start(bot_token=BOT_TOKEN)
    print("✅ Authorized successfully!")

    # Loop through target courses in catalog
    for course in target_courses:
        course_title = course.get("title")
        target_group_name = course.get("group_name")
        thumbnail_url = course.get("thumbnail")
        local_filename = course.get("local_file")
        course_key = local_filename.replace(".json", "").replace(".", "_")

        # Skip if course status is completed in Firebase
        status = get_course_status(course_key)
        if status == "completed":
            print(f"ℹ️ Skipping '{course_title}' (Already cloned fully).")
            continue

        print(f"\n=============================================================")
        print(f"📂 Processing Course: '{course_title}'")
        print(f"=============================================================")

        # Mark course status as processing
        set_course_status(course_key, "processing")

        # Retrieve course cover thumbnail once
        if os.path.exists("thumbnail.jpg"):
            os.remove("thumbnail.jpg")
            
        if thumbnail_url:
            print(f"⏳ Downloading thumbnail: {thumbnail_url}")
            try:
                res = requests.get(thumbnail_url, timeout=15)
                if res.status_code == 200:
                    with open("thumbnail_raw.jpg", "wb") as f:
                        f.write(res.content)
                    
                    # Convert to proper JPEG and resize to max 320x320 for Telegram video thumbnail limit
                    img = Image.open("thumbnail_raw.jpg")
                    if img.mode != "RGB":
                        img = img.convert("RGB")
                    img.thumbnail((320, 320))
                    img.save("thumbnail.jpg", "JPEG", quality=90)
                    if os.path.exists("thumbnail_raw.jpg"):
                        os.remove("thumbnail_raw.jpg")
                    
                    print("✅ Cover thumbnail processed and saved.")
            except Exception as e:
                print(f"⚠️ Cover thumbnail load failed: {e}")

        # Fetch lectures list
        lectures_data = None
        try:
            url = f"{FIREBASE_DB_URL}/{FIREBASE_FOLDER}/courses/{course_key}.json"
            res = requests.get(url, timeout=15)
            lectures_data = res.json()
        except Exception as e:
            print(f"⚠️ Firebase lectures lookup error: {e}")

        if not lectures_data:
            print(f"⚠️ Firebase lectures lookup failed. Reading local file 'courses/{local_filename}'...")
            try:
                with open(os.path.join("courses", local_filename), "r", encoding="utf-8") as f:
                    lectures_data = json.load(f)
            except Exception as e:
                print(f"❌ Failed to load local file 'courses/{local_filename}': {e}")
                continue

        if not lectures_data or "subjects" not in lectures_data:
            print(f"❌ Invalid format in course '{course_title}' details! Skipping...")
            continue

        # Count total files inside this course
        TOTAL_FILES = 0
        for sub in lectures_data["subjects"]:
            if "chapters" in sub:
                for chap in sub["chapters"]:
                    if "lectures" in chap:
                        for lec in chap["lectures"]:
                            if lec.get("link") or lec.get("notes") or lec.get("dpp"):
                                TOTAL_FILES += sum(1 for type_key in ["link", "notes", "dpp"] if lec.get(type_key))

        DONE_COUNT = 0
        FAIL_COUNT = 0

        # Auto-group mapping/creation
        target_group_name = course.get("group_name", course_title).replace(" - Cloner", "").strip()
        
        group_id = get_saved_group_id(course_key)
        if not group_id:
            print(f"⏳ Group mapping not found. Creating private megagroup: '{target_group_name}'...")
            while True:
                try:
                    create_res = await user_client(CreateChannelRequest(
                        title=target_group_name,
                        about=f"Complete lectures for {course_title}.",
                        megagroup=True
                    ))
                    new_channel = create_res.chats[0]
                    group_id = int(f"-100{new_channel.id}")
                    
                    print(f"✅ Megagroup created with ID: {group_id}. Converting to Forum mode...")
                    await user_client(ToggleForumRequest(channel=new_channel, enabled=True, tabs=False))
                    
                    save_group_id(course_key, group_id)
                    print("⏳ Anti-flood delay: sleeping for 15 seconds...")
                    await asyncio.sleep(15)
                    break # Success, exit retry loop
                except FloodWaitError as e:
                    print(f"⚠️ Telegram FloodWait: Sleeping for {e.seconds} seconds before retrying group creation...")
                    await asyncio.sleep(e.seconds + 2)
                except Exception as e:
