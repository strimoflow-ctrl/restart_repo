def sanitize_filename(name):
    return "".join(c for c in name if c.isalnum() or c in " ._-()[]").strip()

def get_md5_hash(text):
    clean_str = "".join(c for c in text if 0 <= ord(c) <= 0x10FFFF and not (0xD800 <= ord(c) <= 0xDFFF))
    return hashlib.md5(clean_str.encode('utf-8', 'ignore')).hexdigest()

def get_disk_space_gb():
    total, used, free = shutil.disk_usage("/")
    return free / (1024 ** 3)

def format_time(seconds):
    h = int(seconds // 3600)
    m = int((seconds % 3600) // 60)
    s = int(seconds % 60)
    return f"{h:02d}:{m:02d}:{s:02d}"

# Unicode stylizer helper converting standard letters/numbers to bold math sans-serif
def to_stylish_bold(text):
    result = []
    for c in text:
        o = ord(c)
        if 65 <= o <= 90: # A-Z
            result.append(chr(o - 65 + 0x1D5D4))
        elif 97 <= o <= 122: # a-z
            result.append(chr(o - 97 + 0x1D5EE))
        elif 48 <= o <= 57: # 0-9
            result.append(chr(o - 48 + 0x1D7EC))
        else:
            result.append(c)
    return "".join(result)

