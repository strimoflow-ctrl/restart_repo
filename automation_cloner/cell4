def get_video_metadata(file_path):
    try:
        cmd = [
            'ffprobe', '-v', 'error', '-show_entries', 
            'format=duration:stream=width,height', '-of', 'json', file_path
        ]
        result = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True, timeout=15)
        data = json.loads(result.stdout)
        duration = float(data['format']['duration'])
        width = int(data['streams'][0]['width'])
        height = int(data['streams'][0]['height'])
        return int(duration), width, height
    except Exception:
        return 0, 1280, 720

def compress_video(input_path, output_path, duration, bot_client, course_key):
    global CURRENT_ACTION
    CURRENT_ACTION = "Compressing video (>2GB)..."
    print(f"🎬 Starting fast compression for {input_path} (Duration: {duration}s)...")
    
    # Target size is 1.85 GB to be safe under 1.9 GB
    target_size_bytes = 1.85 * 1024 * 1024 * 1024
    
    # Calculate target bitrate in bits per second
    total_bitrate = (target_size_bytes * 8) / duration
    video_bitrate = int(total_bitrate - 128 * 1024)
    
    if video_bitrate < 150 * 1024:
        video_bitrate = 150 * 1024
        
    print(f"Target Video Bitrate: {video_bitrate / 1024:.1f} kbps")
    
    # Check if GPU is available (Kaggle T4 or P100 nvenc)
    has_gpu = False
    try:
        subprocess.run(["nvidia-smi"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)
        has_gpu = True
    except Exception:
        pass
        
    if has_gpu:
        print("⚡ GPU detected! Using NVENC hardware acceleration...")
        cmd = [
            'ffmpeg', '-y', '-i', input_path,
            '-b:v', str(video_bitrate),
            '-c:v', 'h264_nvenc', '-preset', 'fast',
            '-c:a', 'aac', '-b:a', '128k',
            output_path
        ]
    else:
        print("💻 Running on CPU. Using ultrafast x264 software compression...")
        cmd = [
            'ffmpeg', '-y', '-i', input_path,
            '-b:v', str(video_bitrate),
            '-c:v', 'libx264', '-preset', 'ultrafast',
            '-c:a', 'aac', '-b:a', '128k',
            output_path
        ]
        
    process = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)
    
    # Read output loop to keep dashboard active
    while True:
        line = process.stdout.readline()
        if not line:
            break
            
    process.wait()
    if process.returncode != 0:
        raise Exception(f"FFmpeg compression failed with return code {process.returncode}")
        
    print(f"✅ Compression complete! Output size: {os.path.getsize(output_path) / (1024*1024):.1f} MB")

async def download_file(url, destination_path, bot_client, course_key):
    global CURRENT_ACTION, CURRENT_FILE_SIZE, CURRENT_SPEED, PROGRESS_PCT
    CURRENT_ACTION = "Downloading link..."
    start_dl_time = time.time()
    
    async with aiohttp.ClientSession() as session:
        async with session.get(url) as response:
            if response.status != 200:
                raise Exception(f"Download returned HTTP {response.status}")
                
            total_size = int(response.headers.get('content-length', 0))
            CURRENT_FILE_SIZE = f"{total_size / (1024*1024):.1f} MB" if total_size > 0 else "Unknown"
            
            downloaded = 0
            with open(destination_path, 'wb') as f:
                async for chunk in response.content.iter_chunked(512 * 1024):
                    if chunk:
                        f.write(chunk)
                        downloaded += len(chunk)
                        
                        if total_size > 0:
                            PROGRESS_PCT = (downloaded / total_size) * 100.0
                            
                        elapsed = time.time() - start_dl_time
                        if elapsed > 0:
                            speed_mbps = ((downloaded * 8) / (1024 * 1024)) / elapsed
                            CURRENT_SPEED = f"{speed_mbps:.1f} Mbps"
                        
                        await update_status_dashboard(bot_client, course_key)

async def fast_upload(client, file_path, progress_callback=None, workers=8):
    file_size = os.path.getsize(file_path)
    file_name = os.path.basename(file_path)
    part_size = 512 * 1024
    part_count = math.ceil(file_size / part_size)
    is_big = file_size > 10 * 1024 * 1024
    file_id = int.from_bytes(os.urandom(8), "big", signed=True)
    uploaded_bytes = 0
    queue = asyncio.Queue()
    
    for i in range(part_count):
        queue.put_nowait(i)
        
    async def upload_worker():
        nonlocal uploaded_bytes
        with open(file_path, "rb") as f:
            while True:
                try:
                    part_idx = queue.get_nowait()
                except asyncio.QueueEmpty:
                    break
                
                f.seek(part_idx * part_size)
                chunk = f.read(part_size)
                
                for attempt in range(3):
                    try:
                        if is_big:
                            await client(SaveBigFilePartRequest(
                                file_id=file_id,
                                file_part=part_idx,
                                file_total_parts=part_count,
                                bytes=chunk
                            ))
                        else:
                            await client(SaveFilePartRequest(
                                file_id=file_id,
                                file_part=part_idx,
                                bytes=chunk
                            ))
                        break
                    except Exception as e:
                        if attempt == 2:
                            raise e
                        await asyncio.sleep(1)
                
                uploaded_bytes += len(chunk)
                if progress_callback:
                    progress_callback(uploaded_bytes, file_size)
                queue.task_done()
                
    tasks = [asyncio.create_task(upload_worker()) for _ in range(workers)]
    await asyncio.gather(*tasks)
    
    if is_big:
        return InputFileBig(id=file_id, parts=part_count, name=file_name)
    else:
        return InputFile(id=file_id, parts=part_count, name=file_name, md5_checksum="")

async def upload_file_with_progress(user_client, bot_client, target_group, file_path, thread_id, caption, course_key, is_video=False):
    global CURRENT_ACTION, CURRENT_SPEED, PROGRESS_PCT
    CURRENT_ACTION = "Uploading with user session..."
    start_ul_time = time.time()
    
    def telethon_callback(sent, total):
        global PROGRESS_PCT, CURRENT_SPEED
        PROGRESS_PCT = (sent / total) * 100.0
        elapsed = time.time() - start_ul_time
        if elapsed > 0:
            speed_mbps = ((sent * 8) / (1024 * 1024)) / elapsed
            CURRENT_SPEED = f"{speed_mbps:.1f} Mbps"
            
        loop = asyncio.get_event_loop()
        if loop.is_running():
            asyncio.ensure_future(update_status_dashboard(bot_client, course_key))

    attributes = []
    thumbnail_path = "thumbnail.jpg" if os.path.exists("thumbnail.jpg") else None
    
    if is_video:
        duration, w, h = get_video_metadata(file_path)
        attributes.append(DocumentAttributeVideo(
            duration=duration,
            w=w,
            h=h,
            supports_streaming=True
        ))

    uploaded_file = await fast_upload(user_client, file_path, progress_callback=telethon_callback, workers=8)
    CURRENT_ACTION = "Finalizing Telegram send..."
    
    await user_client.send_file(
        target_group,
        uploaded_file,
        reply_to=thread_id,
        caption=caption,
        attributes=attributes,
        thumb=thumbnail_path,
        supports_streaming=True,
        force_document=False
    )

